# ============================================================================
# ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control - it contains secrets!
# 
# IMPORTANT SECURITY NOTES:
# - Update all default values before deploying to production
# - Use strong, unique values for SECRET_KEY and database passwords
# - Set DEBUG=False in production
# - Use specific ALLOWED_HOSTS, never use '*' in production
# ============================================================================

# ============================================================================
# DJANGO CORE SETTINGS
# ============================================================================

# SECRET_KEY: Used for cryptographic signing (sessions, CSRF tokens, etc.)
# CRITICAL: Generate a secure key and keep it secret!
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# MUST be changed for production deployment!
SECRET_KEY=your-secure-secret-key-here-min-50-chars-recommended

# DEBUG: Enable/disable debug mode
# WARNING: NEVER set to True in production - exposes sensitive information
# Valid values: True or False
DEBUG=False

# ALLOWED_HOSTS: Comma-separated list of allowed hostnames/IPs
# IMPORTANT: Use specific hostnames in production, never use '*'
# Examples: 
#   Development: localhost,127.0.0.1
#   Production: example.com,www.example.com,api.example.com
ALLOWED_HOSTS=127.0.0.1,localhost

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# SECURE_HSTS_SECONDS: HTTP Strict-Transport-Security max age (seconds)
# Recommended production value: 31536000 (1 year)
# Only effective when serving over HTTPS
SECURE_HSTS_SECONDS=31536000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# SQLite is used by default (no configuration needed)
# 
# For PostgreSQL, ensure DB credentials are strong and change the defaults:
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=image_annotator
DB_USER=postgres
DB_PASSWORD=change-this-password-in-production
DB_HOST=localhost
DB_PORT=5432

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Comma-separated list of allowed origins for CORS requests
# IMPORTANT: Only include trusted frontend URLs
# Remove localhost origins in production
# Examples: 
#   Development: http://localhost:3000,http://localhost:5173
#   Production: https://yourdomain.com,https://www.yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# ============================================================================
# DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production, ensure:
# 
# ✓ SECRET_KEY: Unique, secure, and NOT starting with 'django-insecure-'
# ✓ DEBUG: Set to False
# ✓ ALLOWED_HOSTS: Updated with your actual domain(s)
# ✓ Database: Configured with strong credentials
# ✓ CORS_ALLOWED_ORIGINS: Updated with production frontend URL(s)
# ✓ .env file: Added to .gitignore (never commit it!)
# ✓ HTTPS: Configured on your server
# ✓ Security headers: Properly configured via settings.py
# ============================================================================
